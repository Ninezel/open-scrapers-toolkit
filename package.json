{
  "name": "open-scrapers-toolkit",
  "version": "0.3.0",
  "description": "Open-source TypeScript scrapers for news, weather, reports, and academic research sources.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./discord": {
      "import": "./dist/integrations/discord.js",
      "types": "./dist/integrations/discord.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "open-scrapers": "dist/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "test": "node --import tsx --test test/catalog.test.ts test/cli.test.ts test/discord.test.ts test/http.test.ts test/library.test.ts test/output.test.ts test/publishers.test.ts test/url-links.test.ts test/utils.test.ts",
    "test:live": "node --import tsx --test test/live-sources.test.ts",
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "check:src": "tsc -p tsconfig.json --noEmit",
    "check:test": "tsc -p tsconfig.test.json",
    "check": "npm run check:src && npm run check:test",
    "start": "node dist/cli.js",
    "list": "tsx src/cli.ts list",
    "run:all": "tsx src/cli.ts run-all --out-dir output",
    "health": "tsx src/cli.ts health --format table"
  },
  "keywords": [
    "scraping",
    "rss",
    "research",
    "weather",
    "news",
    "discord-bots",
    "discordjs",
    "open-source",
    "typescript"
  ],
  "license": "MIT",
  "dependencies": {
    "cheerio": "^1.1.2",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "fast-xml-parser": "^5.5.9"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2"
  }
}
