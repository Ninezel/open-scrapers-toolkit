{
  "name": "open-scrapers-toolkit",
  "version": "0.1.0",
  "description": "Open-source TypeScript scrapers for news, weather, reports, and academic research sources.",
  "type": "module",
  "bin": {
    "open-scrapers": "dist/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/cli.js",
    "list": "tsx src/cli.ts list",
    "run:all": "tsx src/cli.ts run-all --out-dir output"
  },
  "keywords": [
    "scraping",
    "rss",
    "research",
    "weather",
    "news",
    "open-source",
    "typescript"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "fast-xml-parser": "^5.5.9"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.2"
  }
}
